# Agent Service API Keys Configuration
# IMPORTANT: Never commit real API keys to version control
# Copy this file to .env.agent and fill in your actual keys

# Stock API (Alpha Vantage)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Web Search API (Tavily)
TAVILY_API_KEY=your_tavily_api_key_here

# Baidu Qianfan API (百度千帆)
BAIDU_QIANFAN_API_KEY=your_baidu_qianfan_key_here

# Weather API (和风天气)
QWEATHER_API_KEY=your_qweather_api_key_here
QWEATHER_API_HOST=https://devapi.qweather.com

# Amap MCP API (高德地图)
AMAP_API_KEY=your_amap_api_key_here

# Service Configuration
ENABLE_NETWORK_FALLBACK=true
USE_ROUTE_OVERRIDE=true

# Baidu Maps MCP API (百度地图)
BAIDU_MAP_API_KEY=your_baidu_map_api_key_here
BAIDU_MAPS_MCP_ENABLED=true
BAIDU_MAPS_MCP_TIMEOUT=3.0

# Intent LLM (2B Model for Intent Classification)
INTENT_LLM_URL=http://localhost:1234/api/v1/chat
INTENT_LLM_MODEL=qwen3-vl-2b-instruct
BING_MCP_ENABLED=false
USE_4B_ROUTER=true
USE_LLM_ROUTER=false
