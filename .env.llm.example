# LLM服务配置示例

# ============================================
# 基础配置
# ============================================

# 推理框架选择: lm_studio, vllm, ollama, openai_compatible, coze
LLM_PROVIDER=vllm

# 运行环境: dev, staging, prod
LLM_ENVIRONMENT=prod

# 推理服务基础URL
LLM_BASE_URL=http://vllm-server:8000

# API密钥（仅OpenAI兼容接口需要）
# LLM_API_KEY=sk-xxxxx

# 模型名称
LLM_MODEL_NAME=qwen2.5-7b-instruct

# 请求超时时间（秒）
LLM_TIMEOUT_SEC=60

# ============================================
# 推理参数
# ============================================

# 温度参数（0.0-2.0，越低越确定）
LLM_TEMPERATURE=0.2

# 最大生成token数
LLM_MAX_TOKENS=512

# Top-P采样参数
LLM_TOP_P=0.95

# Top-K采样参数
LLM_TOP_K=50

# ============================================
# 重试配置
# ============================================

# 最大重试次数
LLM_RETRY_MAX=3

# 初始重试延迟（秒）
LLM_RETRY_INITIAL_DELAY=1.0

# 最大重试延迟（秒）
LLM_RETRY_MAX_DELAY=30.0

# 重试延迟倍增因子
LLM_RETRY_BACKOFF=2.0

# ============================================
# 熔断器配置
# ============================================

# 是否启用熔断器
LLM_CIRCUIT_BREAKER_ENABLED=true

# 失败次数阈值（达到此值后熔断器打开）
LLM_CIRCUIT_BREAKER_THRESHOLD=5

# 恢复成功次数阈值（半开状态下达到此值后关闭）
LLM_CIRCUIT_BREAKER_SUCCESS=2

# 熔断器打开时长（秒）
LLM_CIRCUIT_BREAKER_TIMEOUT=60.0

# ============================================
# 负载均衡配置
# ============================================

# 是否启用负载均衡
LLM_LOAD_BALANCER_ENABLED=true

# 负载均衡策略: round_robin, least_connections, random
LLM_LOAD_BALANCER_STRATEGY=round_robin

# ============================================
# 监控和日志
# ============================================

# 是否启用日志
LLM_ENABLE_LOGGING=true

# 是否启用指标收集
LLM_ENABLE_METRICS=true

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LLM_LOG_LEVEL=INFO

# ============================================
# 环境特定配置
# ============================================

# 开发环境 - 使用本地LM Studio
# LLM_PROVIDER=lm_studio
# LLM_ENVIRONMENT=dev
# LLM_BASE_URL=http://localhost:1234
# LLM_MODEL_NAME=qwen2.5-7b-instruct-mlx
# LLM_TIMEOUT_SEC=120

# 测试环境 - 使用Ollama
# LLM_PROVIDER=ollama
# LLM_ENVIRONMENT=staging
# LLM_BASE_URL=http://ollama-server:11434
# LLM_MODEL_NAME=qwen2.5:7b
# LLM_TIMEOUT_SEC=120

# 生产环境 - 使用vLLM集群
# LLM_PROVIDER=vllm
# LLM_ENVIRONMENT=prod
# LLM_BASE_URL=http://vllm-lb:8000
# LLM_MODEL_NAME=qwen2.5-7b-instruct
# LLM_TIMEOUT_SEC=60
# LLM_CIRCUIT_BREAKER_ENABLED=true
# LLM_LOAD_BALANCER_ENABLED=true

# 云端部署 - 使用OpenAI兼容接口
# LLM_PROVIDER=openai_compatible
# LLM_ENVIRONMENT=prod
# LLM_BASE_URL=https://api.openai.com
# LLM_API_KEY=sk-xxxxx
# LLM_MODEL_NAME=gpt-3.5-turbo
# LLM_TIMEOUT_SEC=60
