# ========== OpenAI API 配置（必需）==========
OPENAI_API_KEY=your_openai_api_key_here

# ========== 高德地图 MCP 配置（需要申请 API Key）==========
# 申请地址: https://console.amap.com/dev/key/app
# 文档: https://lbs.amap.com/api/mcp-server/summary
AMAP_API_KEY=your_amap_api_key_here
AMAP_MCP_SERVER_URL=https://mcp.amap.com/v1
# 传输方式: sse (默认) 或 http
# AMAP_MCP_TRANSPORT=sse

# ========== 小红书 MCP 配置（不需要 API Key，使用扫码登录）==========
# GitHub: https://github.com/xpzouying/xiaohongshu-mcp
# 方式1: 使用本地 Python MCP 服务器（推荐，需要 Python 环境）
XHS_MCP_COMMAND=python
XHS_MCP_ARGS=-m,xiaohongshu_mcp

# 方式2: 使用 HTTP/SSE MCP 服务（如果提供）
# XHS_MCP_SERVER_URL=https://api.xiaohongshu.com/mcp
# XHS_MCP_TRANSPORT=sse

# ========== 服务器配置 ==========
PORT=3001
NODE_ENV=development
